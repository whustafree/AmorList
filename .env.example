# ============================================
# AmorList v2.0 — Variables de Entorno
# ============================================
# Copia este archivo como .env y completa los valores

# Puerto del servidor (opcional, default: 3000)
PORT=3000

# ID de la carpeta de Google Drive que contiene los álbumes
DRIVE_FOLDER_ID=tu_folder_id_aqui

# Credenciales de servicio de Google Cloud (JSON string escapado)
# O puedes poner el archivo credenciales.json en la raíz del proyecto
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"..."}

# Orígenes permitidos para CORS (separados por coma)
# Deja vacío para permitir todos los orígenes (*)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# URL externa (para auto-ping en Render/Heroku)
# Opcional — evita que el servidor se duerma por inactividad
RENDER_EXTERNAL_URL=https://tu-app.onrender.com
# MY_URL=https://tu-app.onrender.com
